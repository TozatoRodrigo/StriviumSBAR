JWT_SECRET=replace-with-random-secret-at-least-32-characters
REFRESH_TOKEN_STRICT_MODE=true

# Rate limiting (slowapi). Use Redis so limits are shared across API instances.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=redis://replace-with-production-redis-host:6379/0
RATE_LIMIT_DEFAULT=100/minute;1000/hour
RATE_LIMIT_AUTH_LOGIN=5/minute
RATE_LIMIT_AUTH_TENANT=10/minute

DB_DRIVER=postgresql
DB_HOST=replace-with-production-db-host
DB_PORT=5432
DB_NAME=strivium_api
DB_USER=strivium_api
DB_PASSWORD=replace-with-production-db-password
DB_DEBUG=false

APP_URL=https://api.link.strivium.com.br
ENABLE_DOCS=false
APP_MODULE=
CORS_ALLOWED_ORIGINS=https://link.strivium.com.br,capacitor://localhost

MAIL_HOST=replace-with-production-smtp-host
MAIL_PORT=587
MAIL_USERNAME=replace-with-production-smtp-user
MAIL_PASSWORD=replace-with-production-smtp-password
MAIL_FROM=no-reply@strivium.com.br
MAIL_USE_TLS=true
TENANT_INVITE_EMAIL_ENABLED=true

FILESYSTEM_DRIVER=s3
S3_PUBLIC_URL=replace-with-production-public-storage-url
S3_BUCKET_NAME=replace-with-production-bucket
S3_ENDPOINT_URL=
S3_AWS_ACCESS_KEY_ID=replace-with-production-access-key
S3_AWS_SECRET_ACCESS_KEY=replace-with-production-secret-key

UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,pdf,mp3,wav,m4a,mp4,mov
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/x-m4a,video/mp4,video/quicktime

TURNSTILE_ENABLED=true
CLOUDFLARE_TURNSTILE_SECRET=replace-with-production-turnstile-secret

SBAR_AI_ENABLED=false
OLLAMA_BASE_URL=https://replace-with-production-sbar-ai-endpoint
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
