JWT_SECRET=changeme-generate-a-random-32-char-secret
REFRESH_TOKEN_STRICT_MODE=true

# Rate limiting (slowapi). Defaults below are fine for single-instance/local dev.
# For multiple API instances, point RATE_LIMIT_STORAGE_URI to the redis service:
#   RATE_LIMIT_STORAGE_URI=redis://strivium-redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=100/minute;1000/hour
RATE_LIMIT_AUTH_LOGIN=5/minute
RATE_LIMIT_AUTH_TENANT=10/minute

# Security response headers (OWASP A05). Enable HSTS only behind HTTPS.
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false

# Audit logs (LGPD). Retention in days (>=180 recommended = ~6 months).
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=180

DB_DRIVER=postgresql
DB_HOST=strivium-db
DB_PORT=5432
DB_NAME=strivium_api
DB_USER=strivium_api
DB_PASSWORD=strivium_api
DB_DEBUG=true

ENABLE_DOCS=true

APP_MODULE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:55000

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_USE_TLS=true
TENANT_INVITE_EMAIL_ENABLED=false

UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,pdf,mp3,wav,m4a,mp4,mov
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/x-m4a,video/mp4,video/quicktime

TURNSTILE_ENABLED=true

CLOUDFLARE_TURNSTILE_SECRET=

SBAR_AI_ENABLED=false
# When running inside Docker use host.docker.internal instead of localhost
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
