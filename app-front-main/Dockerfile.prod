FROM node:22-alpine AS build
WORKDIR /app

COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile --ignore-platform

COPY . .

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY
ARG NEXT_PUBLIC_EXPERIMENTAL_SBAR_VOICE_DICTATION=false
ARG NEXT_PUBLIC_EXPERIMENTAL_SBAR_AI_DICTATION=false

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=${NEXT_PUBLIC_TURNSTILE_SITE_KEY}
ENV NEXT_PUBLIC_EXPERIMENTAL_SBAR_VOICE_DICTATION=${NEXT_PUBLIC_EXPERIMENTAL_SBAR_VOICE_DICTATION}
ENV NEXT_PUBLIC_EXPERIMENTAL_SBAR_AI_DICTATION=${NEXT_PUBLIC_EXPERIMENTAL_SBAR_AI_DICTATION}

RUN yarn build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/out /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
