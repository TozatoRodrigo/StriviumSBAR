NEXT_PUBLIC_API_URL=https://api.link.strivium.com.br
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-production-turnstile-site-key

ANDROID_KEYSTORE_BASE64=replace-with-base64-keystore
ANDROID_KEYSTORE_PASSWORD=replace-with-keystore-password
ANDROID_KEY_ALIAS=replace-with-key-alias
ANDROID_KEY_PASSWORD=replace-with-key-password
GOOGLE_PLAY_CREDENTIALS=replace-with-google-play-service-account-json

MATCH_GIT_URL=git@github.com:your-org/ios-certificates.git
MATCH_PASSWORD=replace-with-match-password
MATCH_GIT_PRIVATE_KEY_BASE64=replace-with-base64-private-key
# Alternative to MATCH_GIT_PRIVATE_KEY_BASE64:
# MATCH_GIT_BASIC_AUTHORIZATION=replace-with-basic-auth-token

APP_STORE_CONNECT_API_KEY_KEY_ID=replace-with-key-id
APP_STORE_CONNECT_API_KEY_ISSUER_ID=replace-with-issuer-id
APP_STORE_CONNECT_API_KEY_KEY=replace-with-p8-content-or-base64
