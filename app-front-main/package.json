{
  "name": "link-front",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 NEXT_IGNORE_INCORRECT_LOCKFILE=1 NEXT_ENABLE_OPTIMIZE_PACKAGE_IMPORTS=true next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 NEXT_IGNORE_INCORRECT_LOCKFILE=1 NEXT_ENABLE_OPTIMIZE_PACKAGE_IMPORTS=true next build",
    "start": "yarn build && yarn serve",
    "serve": "npx serve@latest out",
    "lint": "eslint .",
    "info": "next info",
    "sync": "npx cap sync",
    "release:check-env": "node scripts/release/assert-production-env.mjs",
    "release:check-ci-secrets": "node scripts/release/assert-ci-secrets.mjs",
    "release:github:bootstrap": "node scripts/release/bootstrap-github-release.mjs",
    "release:github:run": "node scripts/release/run-mobile-release.mjs",
    "release:build-web": "node scripts/release/build-web.mjs",
    "release:sync": "node scripts/release/sync-native.mjs",
    "release:sync:android": "node scripts/release/sync-native.mjs android",
    "release:sync:ios": "node scripts/release/sync-native.mjs ios",
    "test": "vitest run",
    "test:contracts:smoke": "vitest run src/hooks/__tests__/api-contracts.smoke.test.ts",
    "test:watch": "vitest",
    "android": "LOCAL_IP=$(ip route get 1.1.1.1 | awk '{print $7; exit}') npx cap run android",
    "android:build": "npx cap build android",
    "ios": "npx cap  run ios",
    "ios:build": "npx cap build ios",
    "ios:remote:signin:copy": "CAPACITOR_SERVER_URL=https://strivium.link.servidortozato.cloud/signin npx cap copy ios"
  },
  "dependencies": {
    "@capacitor/android": "^8",
    "@capacitor/core": "^8",
    "@capacitor/ios": "^8",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.1.1",
    "@marsidev/react-turnstile": "^1.3.1",
    "@mui/icons-material": "^7.1.0",
    "@mui/lab": "^7.0.0-beta.8",
    "@mui/material": "^7.1.0",
    "@mui/material-nextjs": "^7.1.0",
    "@mui/x-date-pickers": "^8.7.0",
    "@tanstack/react-query": "^5.81.0",
    "@tanstack/react-query-devtools": "^5.81.0",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "i18next": "^25.2.1",
    "next": "15.5.10",
    "notistack": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.59.0",
    "react-i18next": "^15.5.3",
    "react-imask": "^7.6.1",
    "react-infinite-scroll-hook": "^6.0.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@capacitor/cli": "^8",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "critters": "^0.0.25",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
